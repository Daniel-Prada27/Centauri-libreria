// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
//   schemas  = ["public"]
}

model Categorias {
  id        String      @id @default(uuid()) @db.Uuid
  nombre    String      @db.VarChar(80)
  productos Productos[]
}

model Autores {
  id        String      @id @default(uuid()) @db.Uuid
  nombre    String      @db.VarChar(45)
  productos Productos[]
}

model Editoriales {
  id        String      @id @default(uuid()) @db.Uuid
  nombre    String      @db.VarChar(45)
  productos Productos[]
}

model Tipos {
  id        String      @id @default(uuid()) @db.Uuid
  nombre    String      @db.VarChar(45)
  productos Productos[]
}

model Productos {
  id                String      @id @default(uuid()) @db.Uuid
  nombre            String      @db.VarChar(100)
  existencias       Int
  fecha_publicacion DateTime    @db.Date

  id_tipo       String
  id_autor      String
  id_editorial  String
  id_categoria  String

  tipo       Tipos       @relation(fields: [id_tipo], references: [id])
  autor      Autores     @relation(fields: [id_autor], references: [id])
  editorial  Editoriales @relation(fields: [id_editorial], references: [id])
  categoria  Categorias  @relation(fields: [id_categoria], references: [id])

  detallesPedido Detalles_Pedidos[]
  carrito        Carritos[]
}

model Clientes {
  id          String    @id @default(uuid()) @db.Uuid
  id_usuario  String    @unique
  cedula      String    @db.VarChar(30)
  nombre      String    @db.VarChar(45)
  direccion   String    @db.VarChar(200)
  activo Boolean
  fecha_eliminacion DateTime @db.Date

  usuario Usuarios      @relation(fields: [id_usuario], references: [id])

  pedidos  Pedidos[]
  carritos Carritos[]
}

model Empleados {
  id          String    @id @default(uuid()) @db.Uuid
  id_usuario  String    @unique
  cedula      String    @db.VarChar(30)
  nombre      String    @db.VarChar(45)
  activo      Boolean
  fecha_terminacion DateTime @db.Date

  usuario Usuarios      @relation(fields: [id_usuario], references: [id])

  pedidos Pedidos[]
}

model Usuarios {
    id       String  @id @default(uuid()) @db.Uuid
    usuario  String  @db.VarChar(25)
    clave    String  @db.Text
    correo   String  @db.VarChar(150)

    cliente Clientes?
    empleado Empleados?

}

model Estados {
  id    String      @id @default(uuid()) @db.Uuid
  nombre  String    @db.VarChar(30)

  pedidos Pedidos[]
}

model Pedidos {
  id                 String       @id @default(uuid()) @db.Uuid
  precio               Float
  cantidad_productos   Int
  fecha_pedido         DateTime

  id_cliente  String
  id_empleado String
  id_estado   String

  cliente   Clientes  @relation(fields: [id_cliente], references: [id])
  empleado  Empleados @relation(fields: [id_empleado], references: [id])
  estado    Estados   @relation(fields: [id_estado], references: [id])

  detalles Detalles_Pedidos[]
}

model Detalles_Pedidos {
  id_pedido   String
  id_producto String
  cantidad    Int
  precio      Float

  pedido   Pedidos  @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  producto Productos @relation(fields: [id_producto], references: [id])

  @@id([id_pedido, id_producto]) // PK compuesta
}

model Carritos {
  id_cliente  String
  id_producto String

  cliente  Clientes  @relation(fields: [id_cliente], references: [id], onDelete: Cascade)
  producto Productos @relation(fields: [id_producto], references: [id])

  @@id([id_cliente, id_producto]) // PK compuesta
}

